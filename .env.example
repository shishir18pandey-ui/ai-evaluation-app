# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Optional: override defaults
# llama-3.1-8b-instant: 500K tokens/day, 14.4K req/day, ~6K tokens/min (default — highest quotas, most reliable for the multi-call pipeline)
# llama-3.3-70b-versatile: smarter, but only 100K tokens/day, 1K req/day, 12K tokens/min
# openai/gpt-oss-120b: smartest, but a reasoning model with only 8K tokens/MINUTE on free tier,
#   which the ~40-50-call pipeline blows past → 429s → silent empty extractions. Not recommended for the hosted demo.
LLM_MODEL=llama-3.1-8b-instant

# Deploying to Hugging Face Spaces? Don't commit a .env file — set
# GROQ_API_KEY under Space Settings -> "Variables and secrets" instead.

# Local development: run against Ollama instead of Groq to skip rate limits
# entirely (needs `ollama serve` + the model pulled on this machine). Not usable
# for the public HF Space deployment — there's no GPU/model server there.
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=qwen3-coder:30b
# OLLAMA_BASE_URL=http://localhost:11434/v1
