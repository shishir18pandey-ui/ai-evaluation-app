# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Optional: override defaults
# openai/gpt-oss-120b: bigger model, 131K context, 200K tokens/day, 1K requests/day (default — best quality for a low-traffic public demo)
# llama-3.1-8b-instant: smaller/faster, 500K tokens/day, 14.4K requests/day (best if you're hammering it with heavy testing)
# llama-3.3-70b-versatile: bigger model, only 100K tokens/day, 1K requests/day
LLM_MODEL=openai/gpt-oss-120b

# Deploying to Hugging Face Spaces? Don't commit a .env file — set
# GROQ_API_KEY under Space Settings -> "Variables and secrets" instead.

# Local development: run against Ollama instead of Groq to skip rate limits
# entirely (needs `ollama serve` + the model pulled on this machine). Not usable
# for the public HF Space deployment — there's no GPU/model server there.
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=qwen3-coder:30b
# OLLAMA_BASE_URL=http://localhost:11434/v1
